#!/bin/bash
set -euo pipefail

# Postinstall script for AuSearch PKG installer.
#
# Installs the LaunchAgent for the instant share daemon so it starts
# automatically when the user logs in.
#
# This script runs as root during installation.

LAUNCH_AGENT_SRC="/Applications/AuSearch.app/Contents/Resources/net.boldman.ausearch.instantshare.plist"
LAUNCH_AGENT_LABEL="net.boldman.ausearch.instantshare"

# Discover the current console user (the one actively logged in via GUI).
CONSOLE_USER=""
if [[ -f /dev/console ]]; then
    CONSOLE_USER=$(stat -f "%Su" /dev/console 2>/dev/null || echo "")
fi

# Fallback: look for the most recently active login window user.
if [[ -z "$CONSOLE_USER" ]]; then
    CONSOLE_USER=$(/usr/bin/python3 -c "import systemsetup; print(systemsetup.get_users()[0])" 2>/dev/null || echo "")
fi
if [[ -z "$CONSOLE_USER" ]]; then
    CONSOLE_USER=$(/bin/ls -la /dev/console | /usr/bin/awk '{print $3}' 2>/dev/null || echo "")
fi
# Last resort: use the first user with a UID >= 500 that has a LaunchAgents dir.
if [[ -z "$CONSOLE_USER" ]]; then
    for u in /Users/*; do
        uname=$(basename "$u")
        uid=$(/usr/bin/id -u "$uname" 2>/dev/null || echo 0)
        if [[ "$uid" -ge 500 ]] && [[ -d "$u/Library/LaunchAgents" ]]; then
            CONSOLE_USER="$uname"
            break
        fi
    done
fi

# Also try the /Library/Application Support/CrashReporter/SubmitDiagInfo approach
if [[ -z "$CONSOLE_USER" ]]; then
    CONSOLE_USER=$(/usr/sbin/scutil <<< "show State:/Users/ConsoleUser" | /usr/bin/awk '/Name :/ && ! /loginwindow/ {print $3}' 2>/dev/null || echo "")
fi

if [[ -z "$CONSOLE_USER" ]]; then
    echo "Warning: Could not determine console user. LaunchAgent not loaded." >&2
    echo "The agent will be installed and activated on next login." >&2
    CONSOLE_USER_HOME=""
else
    CONSOLE_USER_HOME=$(/usr/bin/dscl . -read "/Users/$CONSOLE_USER" NFSHomeDirectory 2>/dev/null | /usr/bin/awk '{print $2}')
fi

# Install the LaunchAgent.
if [[ -n "$CONSOLE_USER_HOME" ]] && [[ -f "$LAUNCH_AGENT_SRC" ]]; then
    LAUNCH_AGENTS_DIR="$CONSOLE_USER_HOME/Library/LaunchAgents"
    /bin/mkdir -p "$LAUNCH_AGENTS_DIR"
    /bin/cp -f "$LAUNCH_AGENT_SRC" "$LAUNCH_AGENTS_DIR/"
    /usr/sbin/chown "$CONSOLE_USER:staff" "$LAUNCH_AGENTS_DIR/net.boldman.ausearch.instantshare.plist"
    /bin/chmod 644 "$LAUNCH_AGENTS_DIR/net.boldman.ausearch.instantshare.plist"
    echo "Installed LaunchAgent for user '$CONSOLE_USER'"

    # Bootstrap the agent for the current user session.
    CONSOLE_UID=$(/usr/bin/id -u "$CONSOLE_USER" 2>/dev/null || echo 0)
    if [[ "$CONSOLE_UID" -gt 0 ]]; then
        /bin/launchctl bootstrap "gui/$CONSOLE_UID" "$LAUNCH_AGENTS_DIR/net.boldman.ausearch.instantshare.plist" 2>/dev/null \
            && echo "LaunchAgent bootstrapped for user '$CONSOLE_USER' (UID $CONSOLE_UID)" \
            || echo "Note: LaunchAgent bootstrap deferred (will start on next login)"
    fi
else
    echo "Note: LaunchAgent installation deferred (no console user)." >&2
    echo "The agent will be activated on next login." >&2
fi

exit 0
