{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Module",
      "type": "debugpy",
      "request": "launch",
      "module": "dt_image_search.__main__",
      "env": {
        "DTIS_BUILD_TYPE": "dev"
      },
      "justMyCode": false,
      "logToFile": true
    },
    {
      "name": "Python Debugger: Inspect",
      "type": "debugpy",
      "request": "launch",
      "module": "PyQtInspect",
      "args": [
        "--direct",
        "--qt-support=pyside6",
        "--file",
        "${workspaceFolder}/main_non_module.py"
      ],
      "justMyCode": false,
      "logToFile": true
    },
    {
      "name": "Debug Unit Test: test_dts_index",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tests/unit/test_dts_index.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Debug current file",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Debug DTImageSearch",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/dt_image_search/__main__.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    {
      "name": "Attach to Remote Debug",
      "type": "python",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "justMyCode": false
    },
    {
      "name": "Python: Listen for MSIX App",
      "type": "python",
      "request": "attach",
      "listen": {
        "host": "127.0.0.1",
        "port": 5678
      }
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:src}/macos/ShareExtension",
      "name": "Debug ShareExtension (macos/ShareExtension)",
      "target": "ShareExtension",
      "configuration": "debug",
      "preLaunchTask": "swift: Build Debug ShareExtension (macos/ShareExtension)"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:src}/macos/ShareExtension",
      "name": "Release ShareExtension (macos/ShareExtension)",
      "target": "ShareExtension",
      "configuration": "release",
      "preLaunchTask": "swift: Build Release ShareExtension (macos/ShareExtension)"
    }
  ]
}
