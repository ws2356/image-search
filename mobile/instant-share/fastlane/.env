# App identity
APP_STORE_CONNECT_APP_IDENTIFIER=net.boldman.instant-share
APP_STORE_CONNECT_APP_IDENTIFIER_2=net.boldman.instant-share.ShareExtension
IOS_TEAM_ID=ZU6V838VRQ
FASTLANE_TEAM_ID=
FASTLANE_ITC_TEAM_ID=

# Embedded targets (numbered suffixes). Each _N pair adds a bundle-id → provisioning-profile
# entry to the ExportOptions.plist provisioningProfiles dict. Any number works: _1, _2, _42, etc.
# APP_STORE_CONNECT_APP_IDENTIFIER_1=net.boldman.instant-share.ShareExtension
# IOS_PROVISIONING_PROFILE_SPECIFIER_1=xyn distribute profile shareext

# Build/signing
IOS_CODE_SIGN_IDENTITY=Apple Distribution: Yanan Xin (ZU6V838VRQ)
IOS_KEYCHAIN_PATH=
IOS_SIGNING_STYLE=manual
IOS_PROVISIONING_PROFILE_SPECIFIER=xyn distribute profile
IOS_PROVISIONING_PROFILE_SPECIFIER_2=snap-get extension production
IOS_ALLOW_PROVISIONING_UPDATES=0
IOS_SCHEME=InstantShare
IOS_CONFIGURATION=Release
IOS_DESTINATION=generic/platform=iOS

# Optional overrides
IOS_PROJECT_PATH=
IOS_ARCHIVE_PATH=
IOS_EXPORT_PATH=
IOS_EXPORT_METHOD=app-store-connect
IOS_EXPORT_OPTIONS_PLIST=
IOS_CLEAN_BUILD=1
APP_STORE_METADATA_PATH=./fastlane/metadata
APP_STORE_UPLOAD_SCREENSHOTS=0
APP_STORE_SUBMIT_FOR_REVIEW=0
APP_STORE_AUTOMATIC_RELEASE=0

# App Store Connect login, supply API_KEY_ID and API_KEY_FILE_PATH in .env.credential for API key authentication
# API_KEY_ID=
# API_KEY_ISSUER_ID= # Required for team key, not required for individual key
# API_KEY_FILE_PATH=
